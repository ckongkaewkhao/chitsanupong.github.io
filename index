    <!-- CORE INTERACTION ARCHITECTURE SCRIPT -->
    <script>
        // Data Setups for Landscape Architecture Projects
        const projectData = {
            mahachai: {
                title: "Mahachai Port & Urban Regeneration",
                location: "Samut Sakhon, Thailand / Vision 2050",
                type: "Ecological Infrastructure & Brownfield Development",
                size: "145,000 SQM",
                status: "Academic Vision Master Plan",
                desc: "This design framework proposes a long-term urban regeneration vision for the historical maritime port of Mahachai by 2050. Facing structural obsolescence in traditional fish processing yards and intensifying tidal flooding disruptions, the landscape architecture intervention implements a system of 'Resilient Parks' and tidal mitigation basins. By creating adaptive public spaces that act as seasonal holding sinks for high-water events, the design successfully safeguards the local economic network while reintroducing deep multi-tier coastal ecologies back to the community interface.",
                images: [
                    "images/mahachai-render-1.jpg",
                    "images/mahachai-masterplan.jpg",
                    "images/mahachai-section.jpg"
                ],
                labels: ["01 / Main Perspective (D5 Render Integration)", "02 / Landscape Master Plan Layout", "03 / Environmental Cross-Section Model"]
            },
            saranrat: {
                title: "Saranrat Maneerom Public Park Evaluation",
                location: "Bangkok, Thailand",
                type: "Landscape Performance & Ecological Analysis",
                size: "32,000 SQM",
                status: "Completed Analytical Field Research",
                desc: "An analytical study investigating the ecological matrix performance of the Saranrat Maneerom Public Park within Bangkok’s dense urban configuration. Utilizing spatial mapping and structural cross-section metrics, this evaluative project assesses the park's capabilities in managing surrounding microclimate temperatures and surface stormwater runoff. The final design output manifests as a series of restorative optimization diagrams, laying out strategies to improve systemic ecological connectivity and community physical accessibility.",
                images: [
                    "images/saranrat-diagram-1.jpg",
                    "images/saranrat-site-plan.jpg"
                ],
                labels: ["01 / Site Connectivity Infrastructure Matrix", "02 / Evaluative Landscape Typology Plan"]
            },
            chiangmai: {
                title: "Chiang Mai Zoo Strategic Master Plan",
                location: "Chiang Mai, Thailand",
                type: "Large-Scale Regional Site Planning",
                size: "850,000 SQM",
                status: "Studio Spatial Planning Module",
                desc: "Addressing complex topography and regional recreational demands, this large-scale master plan completely shifts the spatial structure of the Chiang Mai Zoo down its mountain slope terrain. The design structure maps out microclimate pockets to establish context-appropriate animal welfare zoning models while planning experiential public circulation paths that lower terrain steepness stress. The strategy synthesizes complex pedestrian wayfinding, environmental protection goals, and immersive thematic landscape experiences.",
                images: [
                    "images/zoo-render-1.jpg",
                    "images/zoo-zoning-matrix.jpg"
                ],
                labels: ["01 / High-Altitude Overlook Render View", "02 / Macro Eco-Zoning Spatial Framework"]
            }
        };

        // Navigation Engine
        function navigateTo(viewId) {
            document.querySelectorAll('.view-section').forEach(section => {
                section.classList.add('hidden');
            });
            
            const activeSection = document.getElementById(`view-${viewId}`);
            if(activeSection) {
                activeSection.classList.remove('hidden');
                window.scrollTo({ top: 0 });
            }

            const menuButtons = ['about', 'projects', 'contact'];
            menuButtons.forEach(btn => {
                const el = document.getElementById(`nav-${btn}`);
                if(el) {
                    if(btn === viewId) {
                        el.classList.remove('text-neutral-400');
                        el.classList.add('text-neutral-900', 'font-semibold');
                    } else {
                        el.classList.remove('text-neutral-900', 'font-semibold');
                        el.classList.add('text-neutral-400');
                    }
                }
            });
        }

        // Project Deep Dive Page Loader Engine
        function openProject(projectId) {
            const data = projectData[projectId];
            if(!data) return;

            document.getElementById('project-detail-title').innerText = data.title;
            document.getElementById('project-detail-location').innerText = data.location;
            document.getElementById('project-detail-type').innerText = data.type;
            document.getElementById('project-detail-size').innerText = data.size;
            document.getElementById('project-detail-status').innerText = data.status;
            document.getElementById('project-detail-desc').innerText = data.desc;

            const stackContainer = document.getElementById('project-detail-image-stack');
            stackContainer.innerHTML = '';

            data.images.forEach((imgSrc, idx) => {
                const labelText = data.labels && data.labels[idx] ? data.labels[idx] : `0${idx + 1} / Documentation Image`;
                const mediaBlock = document.createElement('div');
                mediaBlock.className = 'space-y-2';
                mediaBlock.innerHTML = `
                    <div class="w-full bg-neutral-100 rounded overflow-hidden border border-neutral-200/40">
                        <img src="${imgSrc}" alt="${data.title} - Layer ${idx}" class="w-full h-auto object-cover block" onerror="this.style.display='none'; this.parentNode.innerHTML='<div class=\\'w-full aspect-[16/10] flex flex-col items-center justify-center p-6 text-center text-xs text-neutral-400 uppercase tracking-wider bg-neutral-100 border border-neutral-200 rounded\\'><div>${labelText}</div><div class=\\'text-[10px] lowercase text-neutral-400/70 mt-2 font-mono\\'>drop file inside: ${imgSrc}</div></div>'">
                    </div>
                    <p class="text-[10px] text-neutral-400 font-normal uppercase tracking-widest pt-1 pl-1">${labelText}</p>
                `;
                stackContainer.appendChild(mediaBlock);
            });

            navigateTo('project-detail');
        }
    </script>
